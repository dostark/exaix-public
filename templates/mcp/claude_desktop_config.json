{
  "mcpServers": {
    "exoframe": {
      "command": "deno",
      "args": [
        "run",
        "--allow-read",
        "--allow-write",
        "--allow-run",
        "--allow-env",
        "--allow-net",
        "/absolute/path/to/ExoFrame/src/main.ts",
        "mcp",
        "start"
      ],
      "env": {
        "EXOFRAME_ROOT": "/absolute/path/to/ExoFrame"
      }
    }
  }
}
