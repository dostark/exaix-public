{
  "name": "@dostark/exoframe",
  "version": "0.1.0",
  "lock": true,
  "exports": "./src/main.ts",
  "tasks": {
    "start": "deno run --allow-all src/cli/exoctl.ts daemon start",
    "start:fg": "deno run --allow-read=. --allow-write=. --allow-net=api.anthropic.com,api.openai.com,localhost:11434 --allow-env=EXO_,HOME,USER --allow-run=git src/main.ts",
    "stop": "deno run --allow-all src/cli/exoctl.ts daemon stop",
    "status": "deno run --allow-all src/cli/exoctl.ts daemon status",
    "dev": "deno run --watch --allow-all src/main.ts",
    "setup": "deno run --allow-all scripts/setup_db.ts",
    "migrate": "deno run --allow-read --allow-write --allow-env --allow-ffi --allow-run scripts/migrate_db.ts",
    "cli": "deno run --allow-all src/cli/exoctl.ts",
    "scenario:test": "deno test --allow-all tests/scenario_framework/",
    "scenario:test:unit": "deno test --allow-all tests/scenario_framework/tests/unit/",
    "test": "deno test --allow-all",
    "test:security": "deno test --allow-all --filter \"[security]\" tests/",
    "test:ci": "deno test --allow-all tests_infra/",
    "test:llama": "EXO_RUN_LLAMA_TESTS=true deno test --allow-all tests/llama_provider_test.ts",
    "test:watch": "deno test --watch --allow-all tests/",
    "test:coverage": "deno run --allow-run --allow-read --allow-write scripts/measure_coverage.ts",
    "coverage": "deno coverage coverage/ --include='^file://.*ExoFrame/src/' --exclude='test\\.(ts|js)$'",
    "coverage:html": "deno coverage coverage/ --include='^file://.*ExoFrame/src/' --exclude='test\\.(ts|js)$' --html",
    "coverage:lcov": "mkdir -p coverage && deno coverage coverage/ --include='^file://.*ExoFrame/src/' --exclude='test\\.(ts|js)$' --lcov --output=coverage/lcov.info",
    "coverage:with-llama": "rm -rf coverage && ./scripts/coverage.sh summary --with-llama",
    "bench": "deno bench --allow-all tests/benchmarks/",
    "lint": "deno lint src/ tests/",
    "fmt": "deno fmt src/ tests/ docs/",
    "fmt:check": "deno fmt --check src/ tests/ docs/",
    "cache": "deno cache src/main.ts",
    "hooks:install": "deno run --allow-read --allow-write scripts/setup_hooks.ts",
    "check": "deno check src/main.ts",
    "check:style": "deno run -A scripts/check_code_style.ts",
    "check:docs": "deno run --allow-all scripts/verify_manifest_fresh.ts",
    "check:arch": "deno run --allow-read scripts/validate_architecture.ts",
    "check:complexity": "deno run --allow-read --allow-net scripts/measure_complexity.ts --threshold 15 --json > complexity.json && deno run --allow-read scripts/check_complexity_breaches.ts && rm complexity.json",
    "compile": "deno compile --allow-all --output exoframe src/main.ts"
  },
  "imports": {
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0-rc.8",
    "@std/fs": "jsr:@std/fs@^0.221.0",
    "@std/path": "jsr:@std/path@^0.221.0",
    "@std/toml": "jsr:@std/toml@^0.221.0",
    "@std/yaml": "jsr:@std/yaml@^1.0.0",
    "@std/text": "jsr:@std/text@^0.221.0",
    "@std/crypto": "jsr:@std/crypto@^0.221.0",
    "@std/encoding": "jsr:@std/encoding@^0.221.0",
    "@std/fmt": "jsr:@std/fmt@^0.221.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0",
    "@db/sqlite": "jsr:@db/sqlite@^0.11.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.8",
    "deno-tui": "https://deno.land/x/deno_tui@v1.1.1/mod.ts",
    "zod": "https://deno.land/x/zod@v3.22.4/mod.ts"
  },
  "exclude": [
    "cov_profile",
    "exoframe",
    "dist"
  ],
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-explicit-any"
      ]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "src/",
      "tests/",
      "docs/",
      "scripts/"
    ]
  },
  "test": {
    "include": ["tests/"]
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.ns", "deno.unstable"],
    "strict": true,
    "checkJs": false
  }
}
