# ============================================
# Exaix .gitignore (Phase 19)
# ============================================

# --------------------------------------------
# Build & Cache
# --------------------------------------------
/.cache
dist/
**/*.log
logs/


# --------------------------------------------
# Test Artifacts
# --------------------------------------------
coverage*/
.coverage/
jscpd-report/
report/
test-*.toml
cov_profile/
.duplication_report/

# Allow agent-facing coverage snapshot (new location)
!.copilot/coverage/
!.copilot/coverage/coverage-summary.md

# --------------------------------------------
# Runtime State (.exa/)
# --------------------------------------------
.exa/*.db
.exa/*.db-shm
.exa/*.db-wal
.exa/daemon.pid
.exa/daemon.log
.exa/cache/
.exa/activity_export.md
.exa/migration-backup/

# --------------------------------------------
# Workspace (User Content)
# --------------------------------------------
Workspace/Requests/
Workspace/Rejected/
Workspace/Plans/
Workspace/Active/
Workspace/Archive/

# --------------------------------------------
# Integration (External Projects)
# --------------------------------------------
Portals/

# --------------------------------------------
# Build Artifacts
# --------------------------------------------
exaix
/.ci-bin/

# Config files
exa.config.toml
