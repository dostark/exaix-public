/**
 * Tests for Provider Registry Pattern (Issue #10: Tight Coupling Between Services)
 *
 * TDD Implementation: Write tests first, then implement the registry pattern
 * to decouple ProviderFactory from concrete provider implementations.
 *
 * Success Criteria:
 * 1. IProviderFactory interface defines contract for provider creation
 * 2. ProviderRegistry can register and retrieve provider factories
 * 3. Concrete factory implementations create correct provider instances
 * 4. Registry-based creation works for all provider types
 * 5. Backward compatibility maintained with legacy direct instantiation
 * 6. Error handling for missing/unregistered providers
 * 7. Performance overhead minimal (<1% of provider creation time)
 */

import { assertEquals, assertExists, assertThrows } from "jsr:@std/assert@^1.0.0";
import {
  IProviderFactory,
  ProviderRegistry,
  MockProviderFactory,
  OllamaProviderFactory,
  LlamaProviderFactory,
  AnthropicProviderFactory,
  OpenAIProviderFactory,
  GoogleProviderFactory,
} from "../../src/ai/provider_registry.ts";
import { IModelProvider } from "../../src/ai/providers.ts";
import { ResolvedProviderOptions } from "../../src/ai/provider_factory.ts";

// ============================================================================
// Test Fixtures
// ============================================================================

class MockTestProvider implements IModelProvider {
  constructor(private options: { id: string; model: string }) {}

  get id(): string {
    return this.options.id;
  }

  get model(): string {
    return this.options.model;
  }

  async generate(): Promise<string> {
    return `mock response from ${this.id}`;
  }

  async *generateStream(): AsyncGenerator<string> {
    yield `mock stream from ${this.id}`;
  }
}

class FailingProviderFactory implements IProviderFactory {
  create(_options: ResolvedProviderOptions): IModelProvider {
    throw new Error("Factory intentionally fails");
  }

  getSupportedProviders(): string[] {
    return ["mock"]; // Use valid provider type for testing
  }
}

// ============================================================================
// Provider Registry Tests
// ============================================================================

Deno.test("ProviderRegistry: starts empty", () => {
  // Clear registry for test isolation
  // Note: In real implementation, we'd need a way to reset registry
  // For now, we'll test the interface contract

  const factory = new MockProviderFactory();
  assertEquals(factory.getSupportedProviders(), ["mock"]);
});

Deno.test("ProviderRegistry: can register and retrieve factories", () => {
  const registry = ProviderRegistry;
  const factory = new MockProviderFactory();

  // Register factory
  registry.register("test-mock", factory);

  // Retrieve factory
  const retrieved = registry.getFactory("test-mock");
  assertExists(retrieved);
  assertEquals(retrieved.getSupportedProviders(), ["mock"]);
});

Deno.test("ProviderRegistry: returns undefined for unregistered providers", () => {
  const registry = ProviderRegistry;

  const retrieved = registry.getFactory("non-existent");
  assertEquals(retrieved, undefined);
});

Deno.test("ProviderRegistry: getSupportedProviders returns all registered types", () => {
  const registry = ProviderRegistry;

  // Register multiple factories
  registry.register("mock1", new MockProviderFactory());
  registry.register("mock2", new MockProviderFactory());

  const supported = registry.getSupportedProviders();
  assertEquals(supported.length >= 2, true); // At least our test registrations
  assertEquals(supported.includes("mock1"), true);
  assertEquals(supported.includes("mock2"), true);
});

Deno.test("ProviderRegistry: factory creates correct provider instance", () => {
  const registry = ProviderRegistry;
  const factory = new MockProviderFactory();

  registry.register("test-factory", factory);

  const options: ResolvedProviderOptions = {
    provider: "mock",
    model: "test-model",
    timeoutMs: 30000,
  };

  const provider = factory.create(options);
  assertExists(provider);
  assertEquals(provider.id, "mock-test-model");
  // Note: IModelProvider interface doesn't expose model directly,
  // but concrete implementations may include it in the ID
});

Deno.test("ProviderRegistry: handles factory creation errors", () => {
  const registry = ProviderRegistry;
  const failingFactory = new FailingProviderFactory();

  registry.register("failing", failingFactory);

  const options: ResolvedProviderOptions = {
    provider: "mock", // Use valid provider type
    model: "test-model",
    timeoutMs: 30000,
  };

  assertThrows(
    () => failingFactory.create(options),
    Error,
    "Factory intentionally fails"
  );
});

