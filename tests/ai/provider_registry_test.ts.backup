// ============================================================================
// Concrete Factory Tests
// ============================================================================

Deno.test("MockProviderFactory: creates MockLLMProvider instances", () => {
  const factory = new MockProviderFactory();

  const options: ResolvedProviderOptions = {
    provider: "mock",
    model: "test-model",
    timeoutMs: 30000,
    mockStrategy: "recorded",
  };






  const provider = factory.create(options);
  assertExists(provider);
  assertEquals(provider.id, "mock-recorded-test-model");
});

Deno.test("OllamaProviderFactory: creates OllamaProvider instances", () => {
  const factory = new OllamaProviderFactory();

  const options: ResolvedProviderOptions = {
    provider: "ollama",
    model: "llama3.2",



 timeoutMs: 30000,
    baseUrl: "http://localhost:11434",
  };

  const provider = factory.create(options);
  assertExists(provider);
  assertEquals(provider.id, "ollama-llama3.2");
});

Deno.test("LlamaProviderFactory: creates LlamaProvider instances", () => {
  const factory = new LlamaProviderFactory();

  const options: ResolvedProviderOptions = {
    provider: "ollama", // Llama uses ollama routing
    model: "codellama:7b",
    timeoutMs: 30000,
    baseUrl: "http://localhost:11434",
  };

  const provider = factory.create(options);
  assertExists(provider);
  // LlamaProvider doesn't expose model in ID, just check it exists
});

Deno.test("AnthropicProviderFactory: requires API key", () => {
  const factory = new AnthropicProviderFactory();

  const options: ResolvedProviderOptions = {
    provider: "anthropic",
    model: "claude-3-sonnet",
    timeoutMs: 30000,
  };

  // Should fail without API key
  assertThrows(
    () => factory.create(options),
    Error,
    "Anthropic provider requires ANTHROPIC_API_KEY"
  );
});

Deno.test("AnthropicProviderFactory: creates provider with API key", () => {
  const factory = new AnthropicProviderFactory();

  // Set API key for test
  Deno.env.set("ANTHROPIC_API_KEY", "test-key");

  try {
    const options: ResolvedProviderOptions = {
      provider: "anthropic",
      model: "claude-3-sonnet",
      timeoutMs: 30000,
    };

    const provider = factory.create(options);
    assertExists(provider);
    assertEquals(provider.id, "anthropic-claude-3-sonnet");
  } finally {
    Deno.env.delete("ANTHROPIC_API_KEY");
  }
});

Deno.test("OpenAIProviderFactory: requires API key", () => {
  const factory = new OpenAIProviderFactory();

  const options: ResolvedProviderOptions = {
    provider: "openai",
    model: "gpt-4",
    timeoutMs: 30000,
  };

  assertThrows(
    () => factory.create(options),
    Error,
    "OpenAI provider requires OPENAI_API_KEY"
  );
});

Deno.test("GoogleProviderFactory: requires API key", () => {
  const factory = new GoogleProviderFactory();

  const options: ResolvedProviderOptions = {
    provider: "google",
    model: "gemini-pro",
    timeoutMs: 30000,
  };

  assertThrows(
    () => factory.create(options),
    Error,
    "Google provider requires GOOGLE_API_KEY"
  );
});

Deno.test("ProviderRegistry: lookup performance is acceptable", () => {
  const registry = ProviderRegistry;
  const factory = new MockProviderFactory();

  registry.register("perf-test", factory);

  const start = performance.now();

  // Perform multiple lookups
  for (let i = 0; i < 1000; i++) {
    const retrieved = registry.getFactory("perf-test");
    assertExists(retrieved);
  }

  const end = performance.now();
  const avgTime = (end - start) / 1000; // Average time per lookup

  // Should be well under 1ms per lookup
  assertEquals(avgTime < 1, true, `Average lookup time: ${avgTime}ms`);
});
